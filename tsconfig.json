{
  "compilerOptions": {
    /* Modern Chrome-only extension target; ES5 is deprecated in TS 6. */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    /* Strict type-safety end-to-end (skill quality gate). */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    /* esbuild does the emit; tsc is typecheck-only. */
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    /* TS 6 explicit defaults (these are no longer inferred in 6.0). */
    "rootDir": "./src",
    "types": ["chrome", "node"],

    /* Smooths the eventual TS 6 -> 7 (native) migration. */
    "stableTypeOrdering": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
